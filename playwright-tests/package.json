{
  "name": "playwright-tests",
  "version": "1.0.0",
  "description": "E2E Integration Tests for Sai Jai WMS",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:ui": "npx playwright test --ui",
    "test:auth": "npx playwright test tests/auth.spec.ts",
    "test:inventory": "npx playwright test tests/inventory.spec.ts",
    "test:receiving": "npx playwright test tests/receiving-distribution.spec.ts",
    "report": "npx playwright show-report",
    "install:browsers": "npx playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "typescript": "^5.0.0"
  }
}